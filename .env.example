# Kubera — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kubera:kubera@postgres:5432/kubera
# Used by Alembic (sync driver) for migration runs
SYNC_DATABASE_URL=postgresql+psycopg2://kubera:kubera@postgres:5432/kubera

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=changeme_generate_a_real_64char_hex_access_secret
REFRESH_SECRET_KEY=changeme_generate_a_real_64char_hex_refresh_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Internal API ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=changeme_generate_a_real_32char_hex_key

# ── Postgres (used by docker-compose) ─────────────────────────────────────────
POSTGRES_USER=kubera
POSTGRES_PASSWORD=kubera
POSTGRES_DB=kubera

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
